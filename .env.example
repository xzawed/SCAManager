# === 필수 환경변수 ===
DATABASE_URL=postgresql://user:password@localhost:5432/scamanager
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your-github-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# === OAuth / 세션 (웹 UI 로그인 필수) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=dev-secret-change-in-production
# Railway 등 리버스 프록시에서 HTTPS redirect_uri 강제 지정
APP_BASE_URL=

# === 선택 환경변수 ===
# Claude AI 리뷰 API 키 (없으면 AI 항목 기본값 적용)
ANTHROPIC_API_KEY=

# 대시보드 REST API 인증 키 (없으면 인증 생략)
API_KEY=

# 사이클 93 Step 2: src/scripts/generate_illustrations.py 가 DALL-E 3 호출 시 사용.
# Cycle 93 Step 2: used by src/scripts/generate_illustrations.py for DALL-E 3 calls.
# Production code 사용 X — 사용자 로컬 1회 실행 도구 한정.
OPENAI_API_KEY=

# === 이메일 알림 (선택, SMTP) ===
# Railway: SMTP_PORT 빈 문자열 금지(pydantic ValidationError) — 값을 지우거나 숫자 지정
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# === DB Failover (온프레미스 장애 시 Supabase 자동 전환) ===
# Supabase URL 설정 시 활성화 (빈 값이면 failover 비활성)
DATABASE_URL_FALLBACK=
# Primary 복구 확인 주기 (초, 기본 30)
DB_FAILOVER_PROBE_INTERVAL=30

# === DB 연결 고급 설정 (온프레미스 PostgreSQL) ===
# SSL 모드: "require", "verify-full", "disable" 등 (빈 값=미적용)
DB_SSLMODE=
# Railway IPv4 강제 우회 (Railway 배포 시 true, 온프레미스 시 false)
DB_FORCE_IPV4=false
# 연결 풀 설정 (기본값 사용 권장, 고부하 환경에서 조정)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# === 다국어 지원 (Phase 1 PR-1a, Cycle 84+) ===
# Multilingual support (English/Korean/Japanese)

# 신규 사용자 기본 언어 (en / ko / ja / 기타 ISO 639-1)
# Default language for new users (en / ko / ja / other ISO 639-1 codes)
DEFAULT_LOCALE=en

# 지원 언어 목록 (쉼표 구분, 공백 제거 의무)
# Supported language list (comma-separated, no internal spaces)
SUPPORTED_LOCALES=en,ko,ja

# 극한 fallback 언어 (모든 감지 실패 시 사용, 기본값 'en' 권장)
# Ultimate fallback when all detection fails (recommend 'en')
LOCALE_FALLBACK=en

# Babel + Jinja2 i18n 번역 파일 위치 (상대 또는 절대 경로)
# Path to Babel + Jinja2 i18n translation files (relative or absolute)
I18N_TRANSLATIONS_DIR=src/i18n/translations

# i18n 기능 kill-switch (운영 사고 시 1로 설정하여 비활성)
# i18n feature kill-switch (set to 1 for emergency disable)
# 1 설정 시: LocaleMiddleware skip → 영문 hardcoded fallback (Phase 1 PR-1b 영역)
# When 1: LocaleMiddleware skipped → English hardcoded fallback (Phase 1 PR-1b scope)
I18N_DISABLED=0
