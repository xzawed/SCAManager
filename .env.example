# === 필수 환경변수 ===
DATABASE_URL=postgresql://user:password@localhost:5432/scamanager
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your-github-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# === OAuth / 세션 (웹 UI 로그인 필수) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=dev-secret-change-in-production
# Railway 등 리버스 프록시에서 HTTPS redirect_uri 강제 지정
APP_BASE_URL=

# === 선택 환경변수 ===
# Claude AI 리뷰 API 키 (없으면 AI 항목 기본값 적용)
ANTHROPIC_API_KEY=

# 대시보드 REST API 인증 키
# 🔴 미설정 시 기본 fail-closed(503) — 아래 API_AUTH_DISABLED=1 로 opt-out 하거나 키를 설정해야 통과
API_KEY=
# 로컬 개발 전용: API_KEY 미설정 상태로 REST API 무인증 통과 허용 (1=허용). 운영 절대 설정 금지.
# Local dev only: allow keyless REST API access when API_KEY is unset (1=allow). NEVER set in production.
API_AUTH_DISABLED=1

# OpenAI 키 — 두 용도:
# OpenAI key — two uses:
#   (1) src/scripts/generate_illustrations.py 의 DALL-E 3 호출 (사용자 로컬 1회 도구)
#       DALL-E 3 calls in generate_illustrations.py (local one-shot tool)
#   (2) 🔴 2nd-LLM 머지 검증자 (프로덕션 gate, #859) — 설정 시 경계밴드 자동머지를
#       OpenAI GPT 가 독립 검증 (API 비용 발생). 미설정 시 검증자 완전 비활성 (순수 opt-in).
#       2nd-LLM merge verifier (prod gate): when set, OpenAI GPT independently verifies
#       boundary-band auto-merges (API cost incurred). Empty = verifier fully disabled (opt-in).
OPENAI_API_KEY=
# 검증자 옵션 (opt-in 튜닝, 미설정 시 default) — Verifier options (opt-in tuning, default if unset)
OPENAI_VERIFIER_MODEL=gpt-5-mini
MERGE_VERIFIER_BAND=10
# kill-switch — 1 시 검증자 비활성 (운영 사고 즉시 차단)
# kill-switch — set to 1 to disable the verifier (immediate operational cutoff)
MERGE_VERIFIER_DISABLED=0
# 검증자 OpenAI-호환 base_url — 무료 호환 공급자(GitHub Models 등)로 추가 비용 0 활성화 (빈 값 = OpenAI 기본 엔드포인트)
# Verifier OpenAI-compatible base_url — point to a free compatible provider (e.g. GitHub Models) for zero added cost (empty = OpenAI default)
VERIFIER_BASE_URL=

# === 이메일 알림 (선택, SMTP) ===
# Railway: SMTP_PORT 빈 문자열 금지(pydantic ValidationError) — 값을 지우거나 숫자 지정
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# === DB Failover (온프레미스 장애 시 Supabase 자동 전환) ===
# Supabase URL 설정 시 활성화 (빈 값이면 failover 비활성)
DATABASE_URL_FALLBACK=
# Primary 복구 확인 주기 (초, 기본 30)
DB_FAILOVER_PROBE_INTERVAL=30

# === RLS role 분리 옵션 A — background 전용 DB URL ===
# RLS role separation Option A — background-only DB URL (docs/runbooks/rls-role-separation.md Phase 2)
# 빈 값이면 DATABASE_URL 재사용 (현행 동작). 설정 시 BYPASSRLS worker role 자격 필수
# Empty reuses DATABASE_URL (current behavior). Must be BYPASSRLS worker role credentials when set
DATABASE_URL_WORKER=

# === 마이그레이션 전용 DB URL (owner role) — RLS Phase 4 "두 번째 벽" ===
# Migration-only DB URL (owner role) — RLS Phase 4 "second wall" (rls-role-separation.md §6)
# 빈 값이면 DATABASE_URL 사용 (현행 동작 보존 — 미설정 시 발효 0).
# Phase 4 에서 DATABASE_URL 이 비-BYPASSRLS app role 로 바뀔 때 owner 자격 마이그레이션을 위해 설정.
# Empty uses DATABASE_URL (current behavior). Set in Phase 4 so migrations keep owner credentials.
MIGRATION_DATABASE_URL=

# === DB 연결 고급 설정 (온프레미스 PostgreSQL) ===
# SSL 모드: "require", "verify-full", "disable" 등 (빈 값=미적용)
DB_SSLMODE=
# Railway IPv4 강제 우회 (Railway 배포 시 true, 온프레미스 시 false)
DB_FORCE_IPV4=false
# 연결 풀 설정 (기본값 사용 권장, 고부하 환경에서 조정)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800

# === 다국어 지원 (Phase 1 PR-1a, Cycle 84+) ===
# Multilingual support (English/Korean/Japanese)

# 신규 사용자 기본 언어 (en / ko / ja / 기타 ISO 639-1)
# Default language for new users (en / ko / ja / other ISO 639-1 codes)
DEFAULT_LOCALE=en

# 지원 언어 목록 (쉼표 구분, 공백 제거 의무)
# Supported language list (comma-separated, no internal spaces)
SUPPORTED_LOCALES=en,ko,ja

# 극한 fallback 언어 (모든 감지 실패 시 사용, 기본값 'en' 권장)
# Ultimate fallback when all detection fails (recommend 'en')
LOCALE_FALLBACK=en

# Babel + Jinja2 i18n 번역 파일 위치 (상대 또는 절대 경로)
# Path to Babel + Jinja2 i18n translation files (relative or absolute)
I18N_TRANSLATIONS_DIR=src/i18n/translations

# i18n 기능 kill-switch (운영 사고 시 1로 설정하여 비활성)
# i18n feature kill-switch (set to 1 for emergency disable)
# 1 설정 시: LocaleMiddleware skip → 영문 hardcoded fallback (Phase 1 PR-1b 영역)
# When 1: LocaleMiddleware skipped → English hardcoded fallback (Phase 1 PR-1b scope)
I18N_DISABLED=0

# === AI 모델 설정 (선택, 기본값 사용 권장) ===
# AI model settings (optional, defaults recommended)

# AI 코드리뷰에 사용할 Claude 모델 ID (기본: claude-sonnet-4-6)
# Claude model ID for AI code review (default: claude-sonnet-4-6)
CLAUDE_REVIEW_MODEL=

# AI 리뷰 응답 출력 토큰 상한 (기본 8192). 저한도 모델(claude-3-haiku 등 4096) 사용 시 그 이하로 하향
# Output-token cap for AI review (default 8192); lower it below the model's output limit for low-output models
# ⚠️ int 필드 — 빈 값 금지(pydantic ValidationError). 변경하지 않으면 기본값 그대로 둔다.
CLAUDE_REVIEW_MAX_TOKENS=8192

# Insight narrative 생성용 Claude 모델 ID (기본: claude-haiku-4-5, 토큰 비용 최적화)
# Claude model ID for insight narrative generation (default: claude-haiku-4-5, cost-optimized)
CLAUDE_INSIGHT_MODEL=

# Anthropic prompt caching (5분 ephemeral) 비활성화 — 1=비활성, 기본 0 (caching 적용)
# Disable Anthropic prompt caching (5-min ephemeral) — 1=disable, default 0 (caching enabled)
DISABLE_PROMPT_CACHE=0

# === 보안 설정 ===
# Security settings

# GitHub Access Token 암호화 키 (미설정 시 평문 저장 — 운영 환경 필수, 32자 이상 랜덤 문자열)
# GitHub Access Token encryption key (plain-text storage if unset — required in production, 32+ random chars)
TOKEN_ENCRYPTION_KEY=

# 엄격 암호화 모드 (1=미암호화 토큰 거부 및 503, 0=경고 후 허용)
# Strict encryption mode (1=reject unencrypted tokens with 503, 0=warn and allow)
STRICT_TOKEN_ENCRYPTION=0

# Telegram Webhook HMAC 서명 시크릿 (미설정 시 서명 검증 없이 모든 요청 수락 — 운영 필수)
# HMAC secret for Telegram webhook signature (unset = no signature check — required in production)
TELEGRAM_WEBHOOK_SECRET=

# n8n Webhook HMAC 서명 시크릿 (미설정 시 서명 검증 없이 모든 요청 수락 — 운영 필수)
# HMAC secret for n8n webhook signature (unset = no signature check — required in production)
N8N_WEBHOOK_SECRET=

# n8n Issue 릴레이에 GitHub repo OAuth 토큰 포함 여부 (default false = 자격증명 유출 차단). true + SECRET 설정 시에만 토큰 전송
# Include the GitHub repo OAuth token in n8n issue relays (default false = credential-leak guard); sent only when true AND secret set
N8N_RELAY_REPO_TOKEN=false

# === 운영 cron API 인증 ===
# Operational cron API authentication

# railway.toml 내부 cron job 전용 인증 키 (미설정 시 모든 cron 503 실패 — weekly_summary 등 미발송)
# Dedicated auth key for internal cron jobs in railway.toml (unset = all cron 503 failure — weekly_summary etc. won't send)
INTERNAL_CRON_API_KEY=

# === SaaS 멀티테넌시 (선택, 기본 비활성) ===
# SaaS multi-tenancy (optional, disabled by default)

# 멀티테넌트 기능 kill-switch (1=비활성, admin 영역 401 반환)
# Multi-tenant feature kill-switch (1=disable, admin endpoints return 401)
SAAS_MULTITENANT_DISABLED=0

# 관리자 이메일 allow-list (쉼표 구분, 미설정 시 admin UI 자동 비활성화)
# Admin email allow-list (comma-separated, admin UI disabled when unset)
SAAS_ADMIN_EMAILS=

# === 운영 사고 긴급 kill-switch ===
# Emergency kill-switches for operational incidents

# Code/Secret Scanning 자동 처리 kill-switch (1=비활성, false-positive 누적 시 즉각 차단)
# Code/Secret Scanning auto-process kill-switch (1=disable, for immediate block on false-positive flood)
SECURITY_AUTO_PROCESS_DISABLED=0

# 자기-분석 루프 방지 kill-switch (1=비활성, webhook 분석 즉시 202 skipped 반환)
# Self-analysis loop guard kill-switch (1=disable, all webhook analysis returns 202 skipped)
SCAMANAGER_SELF_ANALYSIS_DISABLED=0
