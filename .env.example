# === 필수 환경변수 ===
DATABASE_URL=postgresql://user:password@localhost:5432/scamanager
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here
GITHUB_TOKEN=your-github-token
TELEGRAM_BOT_TOKEN=your-telegram-bot-token
TELEGRAM_CHAT_ID=your-telegram-chat-id

# === OAuth / 세션 (웹 UI 로그인 필수) ===
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
SESSION_SECRET=dev-secret-change-in-production
# Railway 등 리버스 프록시에서 HTTPS redirect_uri 강제 지정
APP_BASE_URL=

# === 선택 환경변수 ===
# Claude AI 리뷰 API 키 (없으면 AI 항목 기본값 적용)
ANTHROPIC_API_KEY=

# 대시보드 REST API 인증 키 (없으면 인증 생략)
API_KEY=

# === Observability (Phase E.2, 선택) ===
# Sentry-compatible DSN (미설정 시 비활성, graceful no-op)
# GlitchTip / Self-hosted Sentry / 유료 Sentry 모두 사용 가능
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1

# === DB Failover (온프레미스 장애 시 Supabase 자동 전환) ===
# Supabase URL 설정 시 활성화 (빈 값이면 failover 비활성)
DATABASE_URL_FALLBACK=
# Primary 복구 확인 주기 (초, 기본 30)
DB_FAILOVER_PROBE_INTERVAL=30

# === DB 연결 고급 설정 (온프레미스 PostgreSQL) ===
# SSL 모드: "require", "verify-full", "disable" 등 (빈 값=미적용)
DB_SSLMODE=
# Railway IPv4 강제 우회 (Railway 배포 시 true, 온프레미스 시 false)
DB_FORCE_IPV4=false
# 연결 풀 설정 (기본값 사용 권장, 고부하 환경에서 조정)
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_POOL_TIMEOUT=30
DB_POOL_RECYCLE=1800
